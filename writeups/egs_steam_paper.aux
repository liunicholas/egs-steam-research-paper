\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Panel structure and descriptive statistics. \textbf  {(a)} Histogram of $\ln (\text  {pre-treatment median avg players} + 1)$ across 446 games. \textbf  {(b)} Number of games with first Epic giveaway in each calendar year. \textbf  {(c)} Fraction of games with a proximate repeat giveaway (within 12 months) by cohort year. \textit  {Source:} SteamCharts.com; Epic Games Store giveaway log \citep  {dongre2025}.}}{15}{figure.caption.7}\protected@file@percent }
\newlabel{fig:desc}{{2}{15}{Panel structure and descriptive statistics. \textbf {(a)} Histogram of $\ln (\text {pre-treatment median avg players} + 1)$ across 446 games. \textbf {(b)} Number of games with first Epic giveaway in each calendar year. \textbf {(c)} Fraction of games with a proximate repeat giveaway (within 12 months) by cohort year. \textit {Source:} SteamCharts.com; Epic Games Store giveaway log \citep {dongre2025}}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pooled TWFE event-study coefficients ($\hat  {\theta }_k$, Eq.~\eqref  {eq:pooled}). Game and calendar-month fixed effects; standard errors clustered by game. Omitted category: $k = -1$. Dashed vertical line at $k = 0$ (giveaway month). $N = 38{,}641$ game-month observations; 446 games.}}{15}{figure.caption.8}\protected@file@percent }
\newlabel{fig:pooled}{{3}{15}{Pooled TWFE event-study coefficients ($\hat {\theta }_k$, Eq.~\eqref {eq:pooled}). Game and calendar-month fixed effects; standard errors clustered by game. Omitted category: $k = -1$. Dashed vertical line at $k = 0$ (giveaway month). $N = 38{,}641$ game-month observations; 446 games}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Event-study estimates: TWFE, LP-DiD \citep  {dube2023}, and stacked DiD \citep  {cengiz2019}. LP-DiD uses not-yet-treated controls at each period $k$ independently. Stacked DiD constructs cohort-specific balanced panels with not-yet-treated controls, weighted by $1/\text  {number of stacks per game}$. All estimators share the same $[-12, 12]$ event window; shaded bands are 95\% confidence intervals. Reference period $k = -1$.}}{16}{figure.caption.9}\protected@file@percent }
\newlabel{fig:compare}{{4}{16}{Event-study estimates: TWFE, LP-DiD \citep {dube2023}, and stacked DiD \citep {cengiz2019}. LP-DiD uses not-yet-treated controls at each period $k$ independently. Stacked DiD constructs cohort-specific balanced panels with not-yet-treated controls, weighted by $1/\text {number of stacks per game}$. All estimators share the same $[-12, 12]$ event window; shaded bands are 95\% confidence intervals. Reference period $k = -1$}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Separated TWFE specification ($\hat  {\beta }_k$ coefficients with repeat-event scalar $\hat  {\delta }$). Event-time dummies capture the first-giveaway effect; $\text  {repeat\_event}_{it}$ absorbs the repeat-giveaway level shift. The estimated $\hat  {\delta } = 0.0001$ ($p = 0.999$) confirms that repeat giveaways add no incremental Steam engagement.}}{16}{figure.caption.10}\protected@file@percent }
\newlabel{fig:separated}{{5}{16}{Separated TWFE specification ($\hat {\beta }_k$ coefficients with repeat-event scalar $\hat {\delta }$). Event-time dummies capture the first-giveaway effect; $\text {repeat\_event}_{it}$ absorbs the repeat-giveaway level shift. The estimated $\hat {\delta } = 0.0001$ ($p = 0.999$) confirms that repeat giveaways add no incremental Steam engagement}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Event-study estimates by pre-treatment popularity. Split at the pre-treatment median (59.2 avg players/month): high-traffic ($N = 215$ games, left) and low-traffic ($N = 214$ games, right). High-traffic pre-trend Wald test: $\chi ^2 = 9.35$, $p = 0.589$. Low-traffic: $\chi ^2 = 19.31$, $p = 0.056$.}}{17}{figure.caption.11}\protected@file@percent }
\newlabel{fig:popularity}{{6}{17}{Event-study estimates by pre-treatment popularity. Split at the pre-treatment median (59.2 avg players/month): high-traffic ($N = 215$ games, left) and low-traffic ($N = 214$ games, right). High-traffic pre-trend Wald test: $\chi ^2 = 9.35$, $p = 0.589$. Low-traffic: $\chi ^2 = 19.31$, $p = 0.056$}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Callaway--Sant'Anna cohort-aggregated ATT estimates. Not-yet-treated games serve as controls within each treatment-quarter cohort; estimates are aggregated across 27 cohorts weighted by cohort size. Omitted period: $k = -1$.}}{17}{figure.caption.12}\protected@file@percent }
\newlabel{fig:csatt}{{7}{17}{Callaway--Sant'Anna cohort-aggregated ATT estimates. Not-yet-treated games serve as controls within each treatment-quarter cohort; estimates are aggregated across 27 cohorts weighted by cohort size. Omitted period: $k = -1$}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Randomization placebo test. Histogram of $|\hat  {\theta }_0|$ from 200 permutations of treatment dates (preserving the empirical distribution of treatment months). Red vertical line: actual estimate $|\hat  {\theta }_0| = 0.101$. The 95th percentile of the permutation null is 0.038; empirical $p < 0.001$.}}{18}{figure.caption.13}\protected@file@percent }
\newlabel{fig:placebo}{{8}{18}{Randomization placebo test. Histogram of $|\hat {\theta }_0|$ from 200 permutations of treatment dates (preserving the empirical distribution of treatment months). Red vertical line: actual estimate $|\hat {\theta }_0| = 0.101$. The 95th percentile of the permutation null is 0.038; empirical $p < 0.001$}{figure.caption.13}{}}
