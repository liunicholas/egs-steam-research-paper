\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Steam player engagement (log scale) around Epic free giveaways. \textbf  {Left:} Density histogram of $\ln (\texttt  {avg\_players}+1)$ for pre-giveaway months ($k < 0$, blue) and post-giveaway months ($k \geq 0$, orange), pooled across all 446 games. \textbf  {Right:} Unconditional mean (with 95\% CI) of the outcome by event-time $k \in [-12,12]$; the dashed vertical line marks the giveaway month ($k = 0$). \textit  {Source:} SteamCharts.com; Epic Games Store giveaway log \citep  {dongre2025}.}}{14}{figure.caption.6}\protected@file@percent }
\newlabel{fig:outcome}{{1}{14}{Steam player engagement (log scale) around Epic free giveaways. \textbf {Left:} Density histogram of $\ln (\texttt {avg\_players}+1)$ for pre-giveaway months ($k < 0$, blue) and post-giveaway months ($k \geq 0$, orange), pooled across all 446 games. \textbf {Right:} Unconditional mean (with 95\% CI) of the outcome by event-time $k \in [-12,12]$; the dashed vertical line marks the giveaway month ($k = 0$). \textit {Source:} SteamCharts.com; Epic Games Store giveaway log \citep {dongre2025}}{figure.caption.6}{}}
